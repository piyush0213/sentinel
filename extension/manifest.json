{
  "manifest_version": 3,
  "name": "SENTINEL Protection Layer",
  "version": "1.0",
  "description": "AI Behavioral Protection Layer. Injects the Cool-Down intervention over any trading platform.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_title": "SENTINEL"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ]
}
